# =============================================================================
# AISmartMirror - Professional .gitignore for Python AI / Computer Vision
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Byte-compiled / optimized / DLL files
*.pyc
*.pyo
*.pyd

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
venv/
.venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Environment variables and secrets (never commit)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Build artifacts
# -----------------------------------------------------------------------------
build/
dist/
eggs/
.eggs/
*.egg
*.egg-info/
*.egg-info/

# -----------------------------------------------------------------------------
# Testing and coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# -----------------------------------------------------------------------------
# IDE and editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Logs and temporary files
# -----------------------------------------------------------------------------
logs/
*.log
tmp/
temp/
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Machine learning / AI artifacts
# -----------------------------------------------------------------------------
models/
checkpoints/
datasets/
data/
*.h5
*.hdf5
*.pt
*.pth
*.onnx
*.tflite
*.pb
*.pkl
*.pickle

# -----------------------------------------------------------------------------
# Large media files (use Git LFS if you need to track these)
# -----------------------------------------------------------------------------
*.mp4
*.avi
*.mov
*.mkv
*.wmv
*.flv

# -----------------------------------------------------------------------------
# Operating system
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------
debug_frame.jpg
debug_*.jpg
