# AISmartMirror - Environment Variables
# Copy this file to .env and configure as needed.
# The app runs without any of these for the starter phase.

# Logging
LOG_LEVEL=INFO
DEBUG=false
# Set DEBUG_SAVE_FRAME=true to save first frame as debug_frame.jpg
DEBUG_SAVE_FRAME=false

# Camera (0 = default webcam)
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30
# Backend on Windows: DSHOW, MSMF, or empty for auto
CAMERA_BACKEND=

# Vision
# Confidence: 0.0-1.0. Lower = more sensitive (catches distant faces, more false positives)
FACE_DETECTION_CONFIDENCE=0.4
# Model: 0=short-range (2m), 1=full-range (5m). Use 1 for distant faces
FACE_DETECTION_MODEL=1
KNOWN_FACES_DIR=

# Cloud APIs (optional - leave empty for now)
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
N8N_WEBHOOK_URL=
